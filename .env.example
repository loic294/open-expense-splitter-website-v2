# ============================================
# Frontend Environment Variables (Local Dev)
# ============================================
#
# This file is only for local development (without Docker).
#
# For Docker: Define variables in root .env instead
# See README.md for setup instructions.
# ============================================

# Backend API URL
# For local dev: http://localhost:3000
# For production: Set PUBLIC_BACKEND_URL in root .env instead
# VITE_API_URL=http://localhost:3000

# Auth0 Configuration
# VITE_AUTH0_DOMAIN=your-auth0-domain.auth0.com
# VITE_AUTH0_CLIENT_ID=your-auth0-client-id

# Auth0 API Audience (optional)
# Leave blank for basic OIDC login without API validation
# VITE_AUTH0_AUDIENCE=

# Production API URL
# Only set this when deploying to production
# Overrides VITE_API_URL if set
# VITE_PUBLIC_BACKEND_URL=https://api.example.com
